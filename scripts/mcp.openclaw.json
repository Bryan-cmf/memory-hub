{
  "platform": "openclaw",
  "config_path": "~/.openclaw/openclaw.json",
  "mcp_server": {
    "command": "python3",
    "args": [
      "/Users/Claw/Desktop/MemoryHub/server/mcp_server.py"
    ],
    "env": {
      "EMBEDDING_MODEL": "BAAI/bge-m3",
      "QDRANT_URL": "http://localhost:6333",
      "MEMORY_COLLECTION": "openclaw_mem",
      "SIMILARITY_THRESHOLD": "0.6",
      "MAX_RESULTS": "10"
    }
  },
  "instructions": "Add the 'memory-hub' entry to ~/.openclaw/openclaw.json. Restart openclaw to load."
}