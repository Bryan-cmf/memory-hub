{
  "platform": "deepseek",
  "config_path": "~/.deepseek/mcp.json",
  "mcp_server": {
    "command": "python3",
    "args": [
      "/Users/Claw/Desktop/MemoryHub/server/mcp_server.py"
    ],
    "env": {
      "EMBEDDING_MODEL": "BAAI/bge-m3",
      "QDRANT_URL": "http://localhost:6333",
      "MEMORY_COLLECTION": "deepseek_mem",
      "SIMILARITY_THRESHOLD": "0.6"
    }
  },
  "instructions": "Add the 'memory-hub' entry to ~/.deepseek/mcp.json. Restart deepseek to load."
}